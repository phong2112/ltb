# Shared
NODE_ENV=development

# Public URLs
NEXT_PUBLIC_APP_URL=http://localhost:8080
NEXT_PUBLIC_API_BASE_PATH=/api
VITE_API_BASE_PATH=/api
VITE_MAX_CV_FILE_SIZE_MB=10
API_BASE_URL=http://api:4000

# API
PORT=4000
WEB_ORIGIN=http://localhost:8080
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/hr_copilot?schema=public
# Used only when CV_STORAGE_DRIVER=local.
UPLOAD_DIR=/app/uploads
MAX_CV_FILE_SIZE_MB=10
APPLICATION_RATE_LIMIT_MAX=5
APPLICATION_RATE_LIMIT_WINDOW_SECONDS=60
TRUST_PROXY_HOPS=1
SWAGGER_ENABLED=true

# Admin auth
ADMIN_EMAIL=v.bichlt6@vinsmartfuture.tech
ADMIN_PASSWORD=demo123
ADMIN_NAME=Lường Thị Bích
JWT_ACCESS_TOKEN_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=28800
JWT_REFRESH_TOKEN_SECRET=change-me-to-a-different-long-random-secret
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# CV storage
# Use "vercel-blob" by default so uploaded CV files go to private Vercel Blob storage.
# Use "local" only when you intentionally want files under UPLOAD_DIR.
CV_STORAGE_DRIVER=vercel-blob
# Required when running API outside Vercel, including ./run.sh Docker development.
BLOB_READ_WRITE_TOKEN=
# Required only for Vercel OIDC auth. Vercel sets this when the Blob store is connected to the project.
BLOB_STORE_ID=

# Future providers
EMAIL_API_KEY=
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
