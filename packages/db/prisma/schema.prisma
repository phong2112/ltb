generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ApplicationStatus {
  NEW
  REVIEWING
  CONTACTED
  REPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
  TALENT_POOL
}

enum FileKind {
  CV
  OTHER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  company      String?
  department   String?
  location     String?
  employment   String?
  level        String?
  salaryRange  String?
  tags         String[]      @default([])
  description  String
  requirements String
  benefits     String?
  status       JobStatus     @default(DRAFT)
  urgent       Boolean       @default(false)
  logo         String?
  questions    JobQuestion[]
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

model JobQuestion {
  id        String   @id @default(cuid())
  jobId     String
  label     String
  required  Boolean  @default(false)
  sortOrder Int      @default(0)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
}

model Candidate {
  id              String             @id @default(cuid())
  fullName        String
  email           String?
  normalizedEmail String?
  phone           String?
  normalizedPhone String?
  linkedinUrl     String?
  portfolioUrl    String?
  source          String             @default("career_site")
  notes           String?
  applications    Application[]
  files           CandidateFile[]
  messages        CandidateMessage[]
  followUps       FollowUpTask[]
  activities      ActivityLog[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([email])
  @@index([normalizedEmail])
  @@index([phone])
  @@index([normalizedPhone])
  @@index([createdAt])
}

model Application {
  id                String            @id @default(cuid())
  candidateId       String
  jobId             String
  normalizedEmail   String?
  normalizedPhone   String?
  status            ApplicationStatus @default(NEW)
  salaryExpectation String?
  noticePeriod      String?
  answers           Json?
  consentAccepted   Boolean           @default(false)
  followUpAt        DateTime?
  candidate         Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job               Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  files             CandidateFile[]
  cvParseResult     CvParseResult?
  matchResult       MatchResult?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([candidateId, jobId])
  @@unique([jobId, normalizedEmail])
  @@unique([jobId, normalizedPhone])
  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@index([createdAt])
}

model CandidateFile {
  id             String          @id @default(cuid())
  candidateId    String
  applicationId  String
  kind           FileKind        @default(CV)
  originalName   String
  storedName     String
  mimeType       String
  sizeBytes      Int
  path           String
  candidate      Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  application    Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  cvParseResults CvParseResult[]
  createdAt      DateTime        @default(now())

  @@index([candidateId])
  @@index([applicationId])
  @@index([applicationId, kind])
}

model CvParseResult {
  id              String         @id @default(cuid())
  applicationId   String         @unique
  candidateFileId String?
  status          String         @default("pending")
  summary         String?
  structuredData  Json?
  extractedText   String?
  errorMessage    String?
  application     Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  candidateFile   CandidateFile? @relation(fields: [candidateFileId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([candidateFileId])
}

model MatchResult {
  id                  String      @id @default(cuid())
  applicationId       String      @unique
  score               Int
  strengths           Json
  risks               Json
  missingRequirements Json
  screeningQuestions  Json
  application         Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model MessageTemplate {
  id        String   @id @default(cuid())
  name      String
  channel   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CandidateMessage {
  id          String    @id @default(cuid())
  candidateId String
  channel     String
  direction   String
  content     String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([candidateId])
}

model FollowUpTask {
  id          String    @id @default(cuid())
  candidateId String
  title       String
  dueAt       DateTime
  completedAt DateTime?
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([candidateId])
  @@index([dueAt])
}

model ActivityLog {
  id          String     @id @default(cuid())
  candidateId String?
  actor       String     @default("system")
  action      String
  metadata    Json?
  candidate   Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())

  @@index([candidateId])
  @@index([createdAt])
}
