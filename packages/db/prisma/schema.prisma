generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum ApplicationStatus {
  NEW
  REVIEWING
  CONTACTED
  REPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
  TALENT_POOL
}

enum FileKind {
  CV
  OTHER
}

enum FileStorageTier {
  PRIMARY
  ARCHIVE
}

enum CvParseStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  company      String?
  department   String?
  locations    String[]      @default([])
  employment   String?
  level        String?
  salaryRange  String?
  tags         String[]      @default([])
  description  String
  requirements String
  benefits     String?
  status       JobStatus     @default(DRAFT)
  urgent       Boolean       @default(false)
  logo         String?
  questions    JobQuestion[]
  applications Application[]
  activities   ActivityLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

model JobQuestion {
  id        String   @id @default(cuid())
  jobId     String
  label     String
  required  Boolean  @default(false)
  sortOrder Int      @default(0)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
}

model Candidate {
  id              String             @id @default(cuid())
  fullName        String
  email           String?
  normalizedEmail String?             @unique(map: "Candidate_normalizedEmail_unique_not_null", where: raw("(\"normalizedEmail\" IS NOT NULL)"))
  phone           String?
  normalizedPhone String?             @unique(map: "Candidate_normalizedPhone_unique_not_null", where: raw("(\"normalizedPhone\" IS NOT NULL)"))
  linkedinUrl     String?
  portfolioUrl    String?
  source          String             @default("career_site")
  applications    Application[]
  activities      ActivityLog[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([email])
  @@index([normalizedEmail])
  @@index([phone])
  @@index([normalizedPhone])
  @@index([createdAt])
}

model Application {
  id                    String             @id @default(cuid())
  candidateId           String
  jobId                 String
  submittedFullName     String
  submittedEmail        String?
  submittedPhone        String?
  submittedLinkedinUrl  String?
  submittedPortfolioUrl String?
  /// DB invariant: Application_normalized_contact_required enforces at least one normalized contact.
  /// Prisma Client does not model check constraints, so keep the SQL migration in sync.
  normalizedEmail       String?
  normalizedPhone       String?
  status                ApplicationStatus  @default(NEW)
  salaryExpectation     String?
  noticePeriod          String?
  coverNote             String?
  hrNotes               String?
  answers               Json?
  consentAccepted       Boolean            @default(false)
  candidate             Candidate          @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  job                   Job                @relation(fields: [jobId], references: [id], onDelete: Restrict)
  files                 CandidateFile[]
  cvParseResult         CvParseResult?
  followUpTask          FollowUpTask?
  matchResult           MatchResult?
  messages              CandidateMessage[]
  activities            ActivityLog[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@unique([candidateId, jobId])
  @@unique([jobId, normalizedEmail])
  @@unique([jobId, normalizedPhone])
  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@index([createdAt])
}

model CandidateFile {
  id             String          @id @default(cuid())
  applicationId  String
  kind           FileKind        @default(CV)
  storageTier    FileStorageTier @default(PRIMARY)
  originalName   String
  storedName     String
  mimeType       String
  sizeBytes      Int
  path           String
  archivedAt     DateTime?
  application    Application     @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  cvParseResults CvParseResult[]
  activities     ActivityLog[]
  createdAt      DateTime        @default(now())

  @@index([applicationId])
  @@index([applicationId, kind])
  @@index([storageTier])
}

model CvParseResult {
  id              String         @id @default(cuid())
  applicationId   String         @unique
  candidateFileId String?
  status          CvParseStatus  @default(PENDING)
  summary         String?
  structuredData  Json?
  extractedText   String?
  errorMessage    String?
  application     Application    @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  candidateFile   CandidateFile? @relation(fields: [candidateFileId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([candidateFileId])
}

model MatchResult {
  id                  String      @id @default(cuid())
  applicationId       String      @unique
  score               Int
  strengths           Json
  risks               Json
  missingRequirements Json
  screeningQuestions  Json
  application         Application @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model MessageTemplate {
  id        String   @id @default(cuid())
  name      String
  channel   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CandidateMessage {
  id            String      @id @default(cuid())
  applicationId String
  channel       String
  direction     String
  content       String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now())

  @@index([applicationId])
}

model FollowUpTask {
  id            String      @id @default(cuid())
  applicationId String      @unique
  title         String
  dueAt         DateTime
  completedAt   DateTime?
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([dueAt])
}

model ActivityLog {
  id              String         @id @default(cuid())
  candidateId     String?
  applicationId   String?
  jobId           String?
  candidateFileId String?
  actor           String         @default("system")
  action          String
  metadata        Json?
  candidate       Candidate?     @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  application     Application?   @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  job             Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  candidateFile   CandidateFile? @relation(fields: [candidateFileId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())

  @@index([candidateId])
  @@index([applicationId])
  @@index([jobId])
  @@index([candidateFileId])
  @@index([createdAt])
}
