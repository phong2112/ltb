# Render API dev environment
# Upload this through Render Service > Environment > Add from .env.
# Do not commit a copy with real secrets.

NODE_ENV=production
PORT=4000
WEB_ORIGIN=https://your-vercel-dev-domain.vercel.app
WEB_ORIGINS=https://your-vercel-dev-domain.vercel.app,https://your-project-*-your-team.vercel.app

# Prefer Neon's pooled URL for DATABASE_URL when available.
# Use Neon's direct URL for MIGRATION_DATABASE_URL.
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
MIGRATION_DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
REDIS_URL=rediss://<managed-redis-url>

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password
ADMIN_NAME="Lường Bích"

JWT_ACCESS_TOKEN_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ACCESS_TOKEN_TTL_SECONDS=28800
JWT_REFRESH_TOKEN_SECRET=change-me-to-a-different-long-random-secret-at-least-32-chars
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000

AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=none

CV_STORAGE_DRIVER=r2
CV_ARCHIVE_STORAGE_DRIVER=vercel-blob
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=<bucket-name>
R2_ACCESS_KEY_ID=<access-key-id>
R2_SECRET_ACCESS_KEY=<secret-access-key>
# Keep this configured while old CandidateFile.path rows still point to Vercel Blob.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token_here
MAX_CV_FILE_SIZE_MB=10

AI_PROVIDER=ollama
OLLAMA_BASE_URL=https://<private-ollama-service>
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT_MS=300000
OLLAMA_CONTEXT_LENGTH=16384
AI_JOB_ATTEMPTS=2
CV_EXTRACTION_CONCURRENCY=1
AI_MATCH_CONCURRENCY=1
OCR_MAX_PAGES=10
OCR_TIMEOUT_MS=120000

APPLICATION_RATE_LIMIT_MAX=5
APPLICATION_RATE_LIMIT_WINDOW_SECONDS=60
TRUST_PROXY_HOPS=1
SWAGGER_ENABLED=false

EMAIL_PROVIDER=gmail
EMAIL_FROM=
EMAIL_REPLY_TO=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
